# ── Google Gemini (analysis + generation) ─────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Instagram (optional — only needed if Instagram shows login wall) ──
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Google (Docs + Drive — optional) ──────────────────────────────────
# Create a Service Account in Google Cloud Console:
# 1. Go to console.cloud.google.com → IAM & Admin → Service Accounts
# 2. Create account → Download JSON key
# 3. Enable Google Docs API and Google Drive API
# 4. Share your target Drive folder with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=content-automation@nifty-passkey-467009-u4.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ── Database (History) ─────────────────────────────────────
# Get from: https://www.mongodb.com/atlas/database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/content-engine
